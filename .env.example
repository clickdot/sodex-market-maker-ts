# Authentication
API_KEY=YOUR_API_KEY_NAME          # Name of your API key from SoDEX UI (e.g. SODEX_API_KEY)
API_SECRET=0x...                   # Your API private key (hex)

# SoDEX API Endpoints (Mainnet)
REST_API_URL=https://mainnet-gw.sodex.dev/api/v1/perps
WS_API_URL=wss://mainnet-gw.sodex.dev/ws/perps

# Market Maker Config
ACCOUNT_ID=0                       # Your SoDEX perps account integer ID
SYMBOL_ID=1                        # 1 = BTC-USD
SYMBOL=BTC-USD
SPREAD=0.001                       # 0.1% total spread (half each side)
ORDER_SIZE=0.1                     # Order size in BTC
QUOTE_INTERVAL_MS=5000             # Re-quote interval in milliseconds
